{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@paperclipai/adapter-utils": ["./src/lib/adapter-utils/dist/index"],
      "@paperclipai/adapter-utils/*": ["./src/lib/adapter-utils/dist/*"],
      "vitest": ["./src/lib/test-shims/vitest.d.ts"]
    }
  }
}
